{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/animations/Thinking/**",
              "components/animations/TypeOut/**",
              "components/layout/BottomNav/**",
              "components/layout/Card/**",
              "components/layout/Overline/**",
              "components/layout/PhoneFrame/**",
              "components/layout/ScreenScroll/**",
              "components/layout/StatusBar/**",
              "components/layout/TopBar/**",
              "components/primitives/Avatar/**",
              "components/primitives/Badge/**",
              "components/primitives/Icon/**",
              "components/primitives/SignalBars/**",
              "components/screens/AjustesScreen/**",
              "components/screens/HistoricoScreen/**",
              "components/screens/HomeScreen/**",
              "components/screens/SignallQScreen/**",
              "components/screens/SinalScreen/**",
              "components/screens/SpeedFlow/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Roboto|Material Symbols Outlined))/i]",
        "message": "Font not provided by the design system. Available: Roboto, Material Symbols Outlined."
      },
      {
        "selector": "JSXOpeningElement[name.name='AjustesScreen'] > JSXAttribute > JSXIdentifier[name!=/^(?:style|key|ref|className|style|children)$/]",
        "message": "<AjustesScreen> doesn't accept that prop. Declared props: style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|letter|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: size, letter."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|color|bg|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, color, bg, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='BottomNav'] > JSXAttribute > JSXIdentifier[name!=/^(?:active|onChange|key|ref|className|style|children)$/]",
        "message": "<BottomNav> doesn't accept that prop. Declared props: active, onChange."
      },
      {
        "selector": "JSXOpeningElement[name.name='BottomNav'] > JSXAttribute[name.name='active'] > Literal[value!=/^(?:home|speed|sinal|hist|ajustes)$/]",
        "message": "<BottomNav> active must be one of 'home' | 'speed' | 'sinal' | 'hist' | 'ajustes'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|style|onClick|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, style, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='HistoricoScreen'] > JSXAttribute > JSXIdentifier[name!=/^(?:style|key|ref|className|style|children)$/]",
        "message": "<HistoricoScreen> doesn't accept that prop. Declared props: style."
      },
      {
        "selector": "JSXOpeningElement[name.name='HomeScreen'] > JSXAttribute > JSXIdentifier[name!=/^(?:onNavigate|key|ref|className|style|children)$/]",
        "message": "<HomeScreen> doesn't accept that prop. Declared props: onNavigate."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|color|fill|weight|style|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, color, fill, weight, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Overline'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|style|key|ref|className|style|children)$/]",
        "message": "<Overline> doesn't accept that prop. Declared props: children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PhoneFrame'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|key|ref|className|style|children)$/]",
        "message": "<PhoneFrame> doesn't accept that prop. Declared props: children."
      },
      {
        "selector": "JSXOpeningElement[name.name='ScreenScroll'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|key|ref|className|style|children)$/]",
        "message": "<ScreenScroll> doesn't accept that prop. Declared props: children."
      },
      {
        "selector": "JSXOpeningElement[name.name='SignalBars'] > JSXAttribute > JSXIdentifier[name!=/^(?:level|color|big|key|ref|className|style|children)$/]",
        "message": "<SignalBars> doesn't accept that prop. Declared props: level, color, big."
      },
      {
        "selector": "JSXOpeningElement[name.name='SignallQScreen'] > JSXAttribute > JSXIdentifier[name!=/^(?:onClose|key|ref|className|style|children)$/]",
        "message": "<SignallQScreen> doesn't accept that prop. Declared props: onClose."
      },
      {
        "selector": "JSXOpeningElement[name.name='SinalScreen'] > JSXAttribute > JSXIdentifier[name!=/^(?:style|key|ref|className|style|children)$/]",
        "message": "<SinalScreen> doesn't accept that prop. Declared props: style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SpeedFlow'] > JSXAttribute > JSXIdentifier[name!=/^(?:onNavigate|key|ref|className|style|children)$/]",
        "message": "<SpeedFlow> doesn't accept that prop. Declared props: onNavigate."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:time|key|ref|className|style|children)$/]",
        "message": "<StatusBar> doesn't accept that prop. Declared props: time."
      },
      {
        "selector": "JSXOpeningElement[name.name='Thinking'] > JSXAttribute > JSXIdentifier[name!=/^(?:style|key|ref|className|style|children)$/]",
        "message": "<Thinking> doesn't accept that prop. Declared props: style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TopBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|icon|leading|action|key|ref|className|style|children)$/]",
        "message": "<TopBar> doesn't accept that prop. Declared props: title, icon, leading, action."
      },
      {
        "selector": "JSXOpeningElement[name.name='TypeOut'] > JSXAttribute > JSXIdentifier[name!=/^(?:text|speed|onDone|key|ref|className|style|children)$/]",
        "message": "<TypeOut> doesn't accept that prop. Declared props: text, speed, onDone."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {
      "AjustesScreen": {
        "replaces": []
      },
      "Avatar": {
        "replaces": []
      },
      "Badge": {
        "replaces": []
      },
      "BottomNav": {
